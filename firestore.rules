rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isCoach() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach';
    }

    // ── Swimmers ─────────────────────────────────────────────────────────────
    // Public read — leaderboard, swimmer profiles, and dashboard all need this
    // without requiring login. Scraper writes via Admin SDK (bypasses rules).
    match /swimmers/{id} {
      allow read: if true;
      allow write: if isCoach();
    }

    // ── Attendance ───────────────────────────────────────────────────────────
    // Kept as public read/write to preserve existing behavior.
    match /attendance/{date} {
      allow read, write: if true;
    }

    // ── Groups ───────────────────────────────────────────────────────────────
    // Public read (groups page is accessible without login).
    match /groups/{id} {
      allow read: if true;
      allow write: if isCoach();
    }

    // ── Meets ────────────────────────────────────────────────────────────────
    // New collection — authenticated read, coach write.
    match /meets/{meetId} {
      allow read:  if request.auth != null;
      allow write: if isCoach();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Users can read/write their own profile doc.
    // Coaches can additionally read any user doc (members table on dashboard).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read:        if isCoach();
    }
  }
}
